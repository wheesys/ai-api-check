# ============ 后端服务配置 ============
DEBUG=false
HOST=localhost
PORT=8000

# ============ 数据库 ============
DATABASE_URL=sqlite:///./app.db

# ============ 安全：API Key 加密主密钥 ============
# 留空则首次启动自动生成临时密钥（仅开发用）。生产环境务必显式设置一个 Fernet 密钥。
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_MASTER_KEY=

# ============ CORS（逗号分隔多个前端地址）============
CORS_ORIGINS=http://localhost:5173

# ============ 任务并发 ============
MAX_CONCURRENT_TASKS=2
DEFAULT_MAX_CONCURRENCY_PER_TASK=2
